<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.teamcollab.mapper.NotificationMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.teamcollab.entity.Notification">
        <id column="notification_id" property="notificationId"/>
        <result column="user_id" property="userId"/>
        <result column="type" property="type"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="is_read" property="isRead"/>
        <result column="related_id" property="relatedId"/>
        <result column="related_type" property="relatedType"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 统计用户的未读通知数量 -->
    <select id="countUnread" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM notifications
        WHERE user_id = #{userId} AND is_read = 0
    </select>

    <!-- 将指定通知标记为已读 -->
    <update id="markAsRead">
        UPDATE notifications
        SET is_read = 1
        WHERE notification_id = #{notificationId} AND user_id = #{userId}
    </update>

    <!-- 批量将用户指定类型的通知标记为已读（type 为 null 时标记全部类型） -->
    <update id="markAllAsRead">
        UPDATE notifications
        SET is_read = 1
        WHERE user_id = #{userId}
          AND is_read = 0
          <if test="type != null and type != ''">
              AND type = #{type}
          </if>
    </update>

    <!-- 统计用户指定类型的通知数量（用于去重检查） -->
    <select id="countByUserIdAndType" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM notifications
        WHERE user_id = #{userId}
          AND type = #{type}
    </select>

</mapper>
