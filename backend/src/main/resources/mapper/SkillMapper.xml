<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.teamcollab.mapper.SkillMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.teamcollab.entity.Skill">
        <id column="skill_id" property="skillId"/>
        <result column="skill_name" property="skillName"/>
        <result column="category" property="category"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 分页查询技能列表（支持分类筛选和关键字搜索） -->
    <select id="selectSkillPage" resultMap="BaseResultMap">
        SELECT * FROM skills
        <where>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="keyword != null and keyword != ''">
                AND skill_name LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY category, skill_name
    </select>

    <!-- 查询所有技能分类（去重） -->
    <select id="selectCategories" resultType="java.lang.String">
        SELECT DISTINCT category FROM skills ORDER BY category
    </select>

</mapper>
